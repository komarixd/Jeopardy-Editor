<Page
    x:Class="Jeopardy.InGameCanvas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Jeopardy"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="InGameCanvas"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    Background="Black"
    mc:Ignorable="d">

    <Grid x:Name="Grid1">
        <Canvas
            x:Name="MainCanvas"
            Background="Transparent"
            Focusable="True" />

        <Button
            Margin="0,978,1718,0"
            Background="#333"
            BorderBrush="#555"
            BorderThickness="2"
            Click="GoBack"
            FontSize="25"
            Foreground="White">
            Exit
        </Button>
        <Button
            Margin="1718,978,0,0"
            Background="#333"
            BorderBrush="#555"
            BorderThickness="2"
            Click="Done"
            FontSize="25"
            Foreground="White">
            Done
        </Button>
    </Grid>

</Page>
