<Page
    x:Class="Jeopardy.MainMenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Jeopardy"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainMenuPage"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    mc:Ignorable="d">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <Button
                Width="200"
                Margin="0,0,0,20"
                Background="#333"
                BorderBrush="#555"
                BorderThickness="2"
                Click="Play_Click"
                FontSize="25"
                Foreground="White">
                Play
            </Button>

            <Button
                Margin="0,0,0,20"
                Background="#333"
                BorderBrush="#555"
                BorderThickness="2"
                Click="Edit_Click"
                FontSize="25"
                Foreground="White">
                Edit
            </Button>

            <Button
                Margin="0,0,0,20"
                Background="#333"
                BorderBrush="#555"
                BorderThickness="2"
                Click="Settings_Click"
                FontSize="25"
                Foreground="White">
                Setting
            </Button>

            <Button
                Background="#333"
                BorderBrush="#555"
                BorderThickness="2"
                Click="Exit_Click"
                FontSize="25"
                Foreground="White">
                Exit
            </Button>

        </StackPanel>
    </Grid>
</Page>
