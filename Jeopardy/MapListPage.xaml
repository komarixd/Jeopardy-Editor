<Page
    x:Class="Jeopardy.MapListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Jeopardy"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MapListPage"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    Background="Black"
    mc:Ignorable="d">

    <Grid>

        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Offset="0.0" Color="#2A2A2A" />
                <GradientStop Offset="1.0" Color="#0A0A0A" />
            </RadialGradientBrush>
        </Grid.Background>

        <Label x:Name="Mode">Mode</Label>

        <!--  New Map Box  -->
        <Grid
            x:Name="NewMapPanel"
            Panel.ZIndex="99"
            Visibility="Collapsed">


            <Border Background="#AA000000" />

            <Border
                Width="400"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#2D2D2D"
                BorderBrush="Gray"
                BorderThickness="1">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,15"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Create New Map" />

                    <TextBlock Foreground="LightGray" Text="Map Name:" />
                    <TextBox
                        x:Name="NewMapName"
                        Margin="0,5,0,10"
                        Padding="5" />

                    <TextBlock Foreground="LightGray" Text="Author:" />
                    <TextBox
                        x:Name="NewMapAuthor"
                        Margin="0,5,0,10"
                        Padding="5" />

                    <TextBlock Foreground="LightGray" Text="Diffuculty:" />
                    <TextBox
                        x:Name="NewMapDiff"
                        Margin="0,5,0,10"
                        Padding="5" />

                    <TextBlock Foreground="LightGray" Text="Description:" />
                    <TextBox
                        x:Name="NewMapDesc"
                        Height="60"
                        Margin="0,5,0,10"
                        Padding="5"
                        AcceptsReturn="True"
                        TextWrapping="Wrap" />

                    <StackPanel
                        Margin="0,10,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            Width="80"
                            Margin="5"
                            Click="CreateNewMap"
                            Content="Save Map" />
                        <Button
                            Width="80"
                            Margin="5"
                            Click="HideNewMapPanel"
                            Content="Cancel" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!--  Edit Map Box  -->
        <Grid
            x:Name="EditMapPanel"
            Panel.ZIndex="99"
            Visibility="Collapsed">

            <Border Background="#AA000000" />

            <Border
                Width="400"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#2D2D2D"
                BorderBrush="Gray"
                BorderThickness="1">

                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,15"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Edit Map" />

                    <TextBlock Foreground="LightGray" Text="Map Name:" />
                    <TextBox
                        x:Name="EditMapName"
                        Margin="0,5,0,10"
                        Padding="5" />

                    <TextBlock Foreground="LightGray" Text="Author:" />
                    <TextBox
                        x:Name="EditMapAuthor"
                        Margin="0,5,0,10"
                        Padding="5" />

                    <TextBlock Foreground="LightGray" Text="Diffuculty:" />
                    <TextBox
                        x:Name="EditMapDiff"
                        Margin="0,5,0,10"
                        Padding="5" />

                    <TextBlock Foreground="LightGray" Text="Description:" />
                    <TextBox
                        x:Name="EditMapDesc"
                        Height="60"
                        Margin="0,5,0,10"
                        Padding="5"
                        AcceptsReturn="True"
                        TextWrapping="Wrap" />

                    <StackPanel
                        Margin="0,10,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            Width="80"
                            Margin="5"
                            Click="SaveMapEdit"
                            Content="Save Map" />
                        <Button
                            Width="80"
                            Margin="5"
                            Click="EditJeopardy"
                            Content="Edit" />
                        <Button
                            Width="80"
                            Margin="5"
                            Click="HideEditMapPanel"
                            Content="Cancel" />

                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!--  Search Box  -->
        <Grid Margin="10,20,10,10">
            <TextBox
                x:Name="SearchBox"
                Margin="250,124,589,827"
                Padding="5"
                FontSize="30"
                TextChanged="SearchBox_TextChanged" />
            <TextBlock
                Margin="258,130,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontSize="30"
                Foreground="DarkGray"
                IsHitTestVisible="False"
                Text="Search maps...">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
        <Button
            Margin="1344,141,250,835"
            Background="#333"
            BorderBrush="#555"
            BorderThickness="2"
            Click="ShowNewMapPanel"
            FontSize="30"
            Foreground="White">
            New Map
        </Button>

        <ScrollViewer Margin="250,250,250,0" VerticalScrollBarVisibility="Auto">
            <UniformGrid
                x:Name="MapGrid"
                Margin="10"
                VerticalAlignment="Top"
                Columns="4" />
        </ScrollViewer>



        <Button
            Margin="0,978,1718,0"
            Background="#333"
            BorderBrush="#555"
            BorderThickness="2"
            Click="GoMenu"
            FontSize="25"
            Foreground="White">
            Back
        </Button>

        <Button
            Margin="1718,978,0,0"
            Background="#333"
            BorderBrush="#555"
            BorderThickness="2"
            Click="Refresh"
            FontSize="25"
            Foreground="White">
            Refresh Map
        </Button>

    </Grid>
</Page>
