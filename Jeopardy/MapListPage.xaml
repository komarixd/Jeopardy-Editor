<Page
    x:Class="Jeopardy.MapListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Jeopardy"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MapListPage"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    Background="Black"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="DarkThemeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="280" />
            <Setter Property="Height" Value="65" />
            <Setter Property="Margin" Value="0,0,0,30" />
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="25" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#333333" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#666666" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#000000" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#222222" />
                                <Setter Property="Foreground" Value="#AAAAAA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Offset="0.0" Color="#2A2A2A" />
                <GradientStop Offset="1.0" Color="#0A0A0A" />
            </RadialGradientBrush>
        </Grid.Background>

        <Label x:Name="Mode" Visibility="Collapsed">Mode</Label>

        <Grid
            x:Name="NewMapPanel"
            Panel.ZIndex="99"
            Visibility="Collapsed">
            <Border Background="#AA000000" />
            <Border
                Width="450"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#2D2D2D"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,15"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Create New Map" />
                    <TextBlock Foreground="LightGray" Text="Map Name:" />
                    <TextBox
                        x:Name="NewMapName"
                        Margin="0,5,0,10"
                        Padding="5"
                        FontSize="16" />
                    <TextBlock Foreground="LightGray" Text="Author:" />
                    <TextBox
                        x:Name="NewMapAuthor"
                        Margin="0,5,0,10"
                        Padding="5"
                        FontSize="16" />
                    <TextBlock Foreground="LightGray" Text="Diffuculty:" />
                    <TextBox
                        x:Name="NewMapDiff"
                        Margin="0,5,0,10"
                        Padding="5"
                        FontSize="16" />
                    <TextBlock Foreground="LightGray" Text="Description:" />
                    <TextBox
                        x:Name="NewMapDesc"
                        Height="80"
                        Margin="0,5,0,15"
                        Padding="5"
                        AcceptsReturn="True"
                        FontSize="16"
                        TextWrapping="Wrap" />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Width="120"
                            Height="45"
                            Margin="5,0,5,0"
                            Click="CreateNewMap"
                            Content="Save Map"
                            FontSize="18"
                            Style="{StaticResource DarkThemeButtonStyle}" />
                        <Button
                            Width="120"
                            Height="45"
                            Margin="5,0,0,0"
                            Click="HideNewMapPanel"
                            Content="Cancel"
                            FontSize="18"
                            Style="{StaticResource DarkThemeButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid
            x:Name="EditMapPanel"
            Panel.ZIndex="99"
            Visibility="Collapsed">
            <Border Background="#AA000000" />
            <Border
                Width="450"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#2D2D2D"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,15"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Edit Map" />
                    <TextBlock Foreground="LightGray" Text="Map Name:" />
                    <TextBox
                        x:Name="EditMapName"
                        Margin="0,5,0,10"
                        Padding="5"
                        FontSize="16" />
                    <TextBlock Foreground="LightGray" Text="Author:" />
                    <TextBox
                        x:Name="EditMapAuthor"
                        Margin="0,5,0,10"
                        Padding="5"
                        FontSize="16" />
                    <TextBlock Foreground="LightGray" Text="Diffuculty:" />
                    <TextBox
                        x:Name="EditMapDiff"
                        Margin="0,5,0,10"
                        Padding="5"
                        FontSize="16" />
                    <TextBlock Foreground="LightGray" Text="Description:" />
                    <TextBox
                        x:Name="EditMapDesc"
                        Height="80"
                        Margin="0,5,0,15"
                        Padding="5"
                        AcceptsReturn="True"
                        FontSize="16"
                        TextWrapping="Wrap" />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Width="110"
                            Height="45"
                            Margin="5,0"
                            Click="SaveMapEdit"
                            Content="Save Map"
                            FontSize="18"
                            Style="{StaticResource DarkThemeButtonStyle}" />
                        <Button
                            Width="110"
                            Height="45"
                            Margin="5,0"
                            Click="EditJeopardy"
                            Content="Edit"
                            FontSize="18"
                            Style="{StaticResource DarkThemeButtonStyle}" />
                        <Button
                            Width="110"
                            Height="45"
                            Margin="5,0,0,0"
                            Click="HideEditMapPanel"
                            Content="Cancel"
                            FontSize="18"
                            Style="{StaticResource DarkThemeButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="50,80,50,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="1" Margin="0,0,20,0">
                    <TextBox
                        x:Name="SearchBox"
                        Padding="15,10"
                        VerticalContentAlignment="Center"
                        FontSize="24"
                        TextChanged="SearchBox_TextChanged" />
                    <TextBlock
                        Margin="18,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="24"
                        Foreground="DarkGray"
                        IsHitTestVisible="False"
                        Text="Search maps...">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button
                    Grid.Column="2"
                    Height="Auto"
                    Margin="0"
                    Click="ShowNewMapPanel"
                    Content="New Map"
                    Style="{StaticResource DarkThemeButtonStyle}" />
            </Grid>

            <ScrollViewer
                Grid.Row="1"
                Margin="50,0,50,0"
                Padding="0,0,10,0"
                VerticalScrollBarVisibility="Auto">
                <WrapPanel
                    x:Name="MapGrid"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    ItemWidth="280" />
            </ScrollViewer>

            <Grid Grid.Row="2">

                <Button
                    Margin="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Click="GoMenu"
                    Content="Back"
                    Style="{StaticResource DarkThemeButtonStyle}" />

                <Button
                    Margin="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Click="Refresh"
                    Content="Refresh Map"
                    Style="{StaticResource DarkThemeButtonStyle}" />
            </Grid>
        </Grid>
    </Grid>
</Page>