<Page
    x:Class="Jeopardy.InGameJeopardy"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Jeopardy"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="InGameJeopardy"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    Background="Black"
    KeepAlive="True"
    mc:Ignorable="d">

    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Offset="0.0" Color="#2A2A2A" />
                <GradientStop Offset="1.0" Color="#0A0A0A" />
            </RadialGradientBrush>
        </Grid.Background>

        <Viewbox
            Margin="50"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Stretch="Uniform">
            <StackPanel Orientation="Horizontal">

                <StackPanel
                    x:Name="BoardContainer"
                    VerticalAlignment="Top"
                    Orientation="Horizontal" />
            </StackPanel>
        </Viewbox>

        <Button
            Margin="0,978,1718,0"
            Background="#333"
            BorderBrush="#555"
            BorderThickness="2"
            Click="GoBack"
            FontSize="25"
            Foreground="White">
            Exit
        </Button>
    </Grid>
</Page>
