<Page
    x:Class="Jeopardy.EditJeopardy"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Jeopardy"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="EditJeopardy"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    Background="Black"
    PreviewKeyDown="Page_PreviewKeyDown"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="DarkThemeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="280" />
            <Setter Property="Height" Value="65" />
            <Setter Property="Margin" Value="0,0,0,30" />
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="25" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#333333" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#666666" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#000000" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#222222" />
                                <Setter Property="Foreground" Value="#AAAAAA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>

        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Offset="0.0" Color="#2A2A2A" />
                <GradientStop Offset="1.0" Color="#0A0A0A" />
            </RadialGradientBrush>
        </Grid.Background>

        <Grid
            x:Name="EditPanel"
            Panel.ZIndex="99"
            Visibility="Collapsed">
            <Border Background="#AA000000" />
            <Border
                Width="450"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#2D2D2D"
                BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,15"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Edit Cell" />
                    <TextBlock Foreground="LightGray" Text="Score Value:" />
                    <TextBox
                        x:Name="NewScore"
                        Margin="0,5,0,15"
                        Padding="5"
                        FontSize="18"
                        FontWeight="Bold" />

                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Width="100"
                            Height="45"
                            Margin="5,0"
                            Click="SaveData"
                            Content="Save"
                            FontSize="18"
                            Style="{StaticResource DarkThemeButtonStyle}" />
                        <Button
                            Width="100"
                            Height="45"
                            Margin="5,0"
                            Click="EditGame"
                            Content="Edit"
                            FontSize="18"
                            Style="{StaticResource DarkThemeButtonStyle}" />
                        <Button
                            Width="100"
                            Height="45"
                            Margin="5,0,0,0"
                            Click="HideEditPanel"
                            Content="Cancel"
                            FontSize="18"
                            Style="{StaticResource DarkThemeButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="MapTitleText"
                Grid.Row="0"
                Margin="0,30,0,0"
                HorizontalAlignment="Center"
                FontSize="48"
                FontWeight="Bold"
                Foreground="White"
                Text="Map Title">
                <TextBlock.Effect>
                    <DropShadowEffect
                        BlurRadius="5"
                        Opacity="0.8"
                        ShadowDepth="3"
                        Color="Black" />
                </TextBlock.Effect>
            </TextBlock>

            <Viewbox
                Grid.Row="1"
                Margin="50"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Stretch="Uniform">
                <StackPanel Orientation="Horizontal">

                    <StackPanel
                        x:Name="BoardContainer"
                        VerticalAlignment="Top"
                        Orientation="Horizontal" />

                    <Button
                        x:Name="AddColumnBtn"
                        Width="80"
                        Height="500"
                        Margin="10,0,10,0"
                        Click="AddColumnBtn_Click"
                        Content="+"
                        FontSize="50"
                        FontWeight="Black"
                        Style="{StaticResource DarkThemeButtonStyle}" />
                </StackPanel>
            </Viewbox>

            <Grid Grid.Row="2" Margin="20,0,0,0">
                <Button
                    Margin="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Click="GoBack"
                    Content="Back"
                    Style="{StaticResource DarkThemeButtonStyle}" />
            </Grid>
        </Grid>

    </Grid>
</Page>