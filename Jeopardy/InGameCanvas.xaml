<Page
    x:Class="Jeopardy.InGameCanvas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Jeopardy"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="InGameCanvas"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    Background="Black"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="DarkThemeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#333333"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#666666"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#000000"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#222222"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="Grid1">
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                <GradientStop Offset="0.0" Color="#2A2A2A" />
                <GradientStop Offset="1.0" Color="#0A0A0A" />
            </RadialGradientBrush>
        </Grid.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="HintPanel" Grid.Row="0" Height="115" Background="#1E1E1E" BorderBrush="#444444" BorderThickness="0,0,0,2">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <StackPanel x:Name="HintPageContainer" Margin="10" VerticalAlignment="Center" Orientation="Horizontal" />
                </StackPanel>
            </Border>

            <Canvas x:Name="MainCanvas" Grid.Row="1" Background="Transparent" Focusable="True">
            </Canvas>

            <Grid Grid.Row="2" Margin="20">
                <Button Content="Exit" 
                        Style="{StaticResource DarkThemeButtonStyle}" 
                        HorizontalAlignment="Left" 
                        Click="GoBack"/>

                <Button Content="Done" 
                        Style="{StaticResource DarkThemeButtonStyle}" 
                        HorizontalAlignment="Right" 
                        Click="Done"/>
            </Grid>
        </Grid>

    </Grid>
</Page>